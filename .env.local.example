# ─── Backend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Celo Network ─────────────────────────────────────────────────────────────
# "celo" for mainnet, "alfajores" for testnet
NEXT_PUBLIC_NETWORK=alfajores

# ─── Smart Contract ───────────────────────────────────────────────────────────
# Fill in after deploying PokerEscrow.sol
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYOUR_POKER_ESCROW_ADDRESS

# ─── Dev / Testing ────────────────────────────────────────────────────────────
# Set to "true" to show the "Start Bot Table" button in the lobby
NEXT_PUBLIC_DEV_MODE=true
